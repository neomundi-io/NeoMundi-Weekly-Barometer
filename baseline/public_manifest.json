{
  "release_name": "NeoMundi Weekly Barometer — Baseline V1 Public Draft",
  "status": "draft_for_methodological_review",
  "release_type": "anonymized_runtime_behavior_cartography",
  "panel": {
    "systems": 12,
    "measurement_waves": 3,
    "questions": 4,
    "repetitions_per_question_per_wave": 100,
    "total_observations": 14400
  },
  "identity_policy": {
    "public_identifier": "stable_profile_id",
    "provider_names_published": false,
    "model_names_published": false,
    "private_mapping_included": false
  },
  "public_metrics": {
    "profile_summary": [
      "stability_position_band",
      "coherence_position_band",
      "semantic_risk_position_band",
      "factual_hallucination_position_band",
      "latency_position_band",
      "stability_inter_wave_variability_band",
      "non_allow_decision_position_band",
      "dominant_decision",
      "measurement_coverage_status"
    ],
    "question_profiles": [
      "stability_position_band",
      "coherence_position_band",
      "semantic_risk_position_band",
      "factual_hallucination_position_band",
      "stability_wave_variability_band",
      "non_allow_decision_position_band",
      "dominant_decision"
    ]
  },
  "banding_policy": {
    "method": "five_relative_ordinal_bands",
    "labels": [
      "lowest_panel_band",
      "low_panel_band",
      "mid_panel_band",
      "high_panel_band",
      "highest_panel_band"
    ],
    "meaning": "Bands express relative position within the measured panel, not absolute safety, quality or performance thresholds.",
    "direction_note": "For semantic risk and factual hallucination, a higher position band means a higher observed value in this panel."
  },
  "withheld": [
    "raw_observations",
    "provider_names",
    "model_names",
    "private_mapping",
    "prompt_contents",
    "exact_timestamps",
    "exact_latency_values",
    "exact_cost_values",
    "high_precision_metric_values",
    "source_filenames"
  ],
  "limitations_file": "public_exclusions_and_limitations.csv",
  "artifacts": [
    "public_profiles_summary.csv",
    "public_question_profiles.csv",
    "public_regimes_totals.csv",
    "public_exclusions_and_limitations.csv"
  ]
}